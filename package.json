{
  "name": "nestjs-authkit",
  "version": "1.0.0",
  "description": "A production-grade, drop-in authentication and authorization module for NestJS — JWT handling, refresh token rotation, Redis-backed session revocation, RBAC, and TOTP-based 2FA.",
  "main": "dist/src/index.js",
  "types": "dist/src/index.d.ts",
  "scripts": {
    "build": "rimraf dist && tsc",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest"
  },
  "keywords": [
    "nestjs",
    "authentication",
    "authorization",
    "jwt",
    "refresh-token",
    "rbac",
    "2fa",
    "totp",
    "redis",
    "blocklist",
    "session-revocation",
    "guards"
  ],
  "author": "mohamedsaba",
  "license": "MIT",
  "peerDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.2"
  },
  "dependencies": {
    "@nestjs/jwt": "^11.0.2",
    "ioredis": "^5.10.1",
    "otplib": "^13.4.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.15.1",
    "uuid": "^14.0.0"
  },
  "devDependencies": {
    "@nestjs/common": "^11.1.19",
    "@nestjs/core": "^11.1.19",
    "@nestjs/testing": "^11.1.19",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.6.0",
    "@types/uuid": "^10.0.0",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "@typescript-eslint/parser": "^8.59.0",
    "eslint": "^10.2.1",
    "jest": "^30.3.0",
    "prettier": "^3.8.3",
    "reflect-metadata": "^0.2.2",
    "rimraf": "^6.1.3",
    "rxjs": "^7.8.2",
    "ts-jest": "^29.4.9",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^6.0.3"
  }
}